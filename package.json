{
  "name": "halcon-hdevelop",
  "displayName": "halcon-hdevelop",
  "description": "Edit Halcon HDevelop scripts within VSCode.",
  "version": "1.0.2",
  "engines": {
    "vscode": "^1.71.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onNotebook:halcon-hdevelop"
  ],
  "main": "./dist/extension.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/ClemaX/vscode-halcon-hdevelop.git"
  },
  "bugs": {
    "url": "https://github.com/ClemaX/vscode-halcon-hdevelop/vscode-wordcount/issues",
    "email": "dont@trytofool.me"
  },
  "contributes": {
    "commands": [
      {
        "command": "halcon-hdevelop.selectProcedure",
        "title": "Jump to Function",
        "category": "HDevelop",
        "icon": "$(list-tree)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "halcon-hdevelop.selectProcedure",
          "when": "resourceExtname == .hdev",
          "group": "navigation"
        }
      ]
    },
    "languages": [
      {
        "id": "hdevelop",
        "aliases": [
          "Halcon HDevelop",
          "hdevelop"
        ],
        "extensions": [
          ".hdev"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "hdevelop.api",
        "aliases": [
          "Halcon HDevelop API",
          "hdevelop.api"
        ],
        "extensions": [
          ""
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "hdevelop",
        "scopeName": "source.hdevelop",
        "path": "./syntaxes/hdevelop.tmLanguage.json"
      },
      {
        "language": "hdevelop.api",
        "scopeName": "source.hdevelop.api",
        "path": "./syntaxes/hdevelop.api.tmLanguage.json"
      }
    ],
    "notebooks": [
      {
        "id": "halcon-hdevelop",
        "type": "halcon-hdevelop",
        "displayName": "Halcon HDevelop",
        "selector": [
          {
            "scheme": "file",
            "filenamePattern": "*.hdvp"
          },
          {
            "scheme": "file",
            "filenamePattern": "*.hdev"
          }
        ]
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js",
    "build:mcp": "tsc src/mcp-server.ts --outDir dist/mcp --module commonjs --target ES2022 --moduleResolution node --esModuleInterop --skipLibCheck",
    "mcp": "node dist/mcp/mcp-server.js"
  },
  "devDependencies": {
    "@types/glob": "^7.2.0",
    "@types/mocha": "^9.1.1",
    "@types/node": "16.x",
    "@types/vscode": "^1.71.0",
    "@typescript-eslint/eslint-plugin": "^5.31.0",
    "@typescript-eslint/parser": "^5.31.0",
    "@vscode/test-electron": "^2.1.5",
    "eslint": "^8.20.0",
    "fast-xml-parser": "^4.0.10",
    "glob": "^8.0.3",
    "mocha": "^10.0.0",
    "ts-loader": "^9.3.1",
    "ts-node": "^10.9.2",
    "typescript": "^4.9.5",
    "webpack": "^5.74.0",
    "webpack-cli": "^4.10.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^3.24.0"
  },
  "icon": "images/icon.png",
  "license": "MIT",
  "publisher": "ClemaX"
}
